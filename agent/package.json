{
  "name": "orbit-agent",
  "version": "1.0.0",
  "description": "Modular conversation AI agent backend service with multi-LLM support",
  "main": "dist/app.js",
  "bin": {
    "orbit": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "ts-node -r dotenv/config src/app.ts",
    "invite:reset-bindings": "ts-node -r dotenv/config src/scripts/resetInviteDeviceBindings.ts",
    "build": "tsc && chmod +x dist/cli/index.js",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit",
    "test:unit": "jest --selectProjects unit --forceExit",
    "test:integration": "jest --selectProjects integration --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "cli": "ts-node -r dotenv/config src/cli/index.ts",
    "prepare": "husky install"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "claude",
    "openai",
    "gemini",
    "mcp",
    "mongodb",
    "redis"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/generative-ai": "^0.2.0",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dayjs": "^1.11.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "ink": "^5.2.0",
    "ioredis": "^5.3.0",
    "joi": "^17.11.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "lunar-typescript": "^1.8.6",
    "mongoose": "^8.0.0",
    "openai": "^4.28.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "react": "^18.3.1",
    "typescript": "^5.3.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.17.21",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.18",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "axios": "^1.14.0",
    "eslint": "^8.55.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
