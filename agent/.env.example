# Application
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=orbit_agent
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_URI=mongodb://localhost:27017/orbit_agent

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ LLM API Keys ============

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# DeepSeek (OpenAI 兼容 API)
#   官方地址: https://platform.deepseek.com
#   base_url 使用 OpenAI 兼容格式: https://api.deepseek.com
#   推荐模型: deepseek-v4-flash (普通/思考一体), deepseek-v4-pro
#   兼容旧名: deepseek-chat / deepseek-reasoner (将于 2026/07/24 弃用)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============ OpenAI 兼容模型 ============
# 这些模型使用 OpenAI 兼容 API

# Kimi (Moonshot) - https://platform.moonshot.cn
KIMI_API_KEY=

# SiliconFlow (硅基流动) - https://www.siliconflow.cn
SILICONFLOW_API_KEY=

# Groq - https://console.groq.com
GROQ_API_KEY=

# Together AI - https://api.together.xyz
TOGETHER_API_KEY=

# Perplexity - https://www.perplexity.ai
PERPLEXITY_API_KEY=

# 智谱 AI (Zhipu / GLM + Embedding-3) - https://bigmodel.cn
#   OpenAI 兼容 API base URL: https://open.bigmodel.cn/api/paas/v4
#   chat 模型: glm-4-plus, glm-4-air-250414, glm-4-flash-250414
#   embedding: embedding-3 (默认 2048 维, 可选 1024/512/256), 0.5 元/Mtok
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ============ Auth ============
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# ============ MCP Gateway ============
MCP_GATEWAY_URL=http://localhost:3001
MCP_GATEWAY_TOKEN=

# ============ RAG Embedder ============
#   hash              — default, no external API, low quality
#   remote-zhipu      — 智谱 Embedding-3 (requires ZHIPU_API_KEY above)
# Optional tuning:
#   ZHIPU_EMBED_MODEL=embedding-3   (default; or -512 / -256 for shorter)
#   ZHIPU_EMBED_DIM=2048            (2048/1024/512/256)
ORBIT_EMBEDDER=hash
